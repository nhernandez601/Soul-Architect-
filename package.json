{
  "name": "soul-architect",
  "version": "0.1.0",
  "description": "Soul Architect — A Psychological Dark Fantasy Visual Novel Engine",
  "author": "Soul Architect Team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "concurrently \"vite\" \"electron electron/main/index.ts\"",
    "electron:build": "npm run build && electron-builder",
    "story:validate": "ts-node tools/story-validator/index.ts",
    "localization:check": "ts-node tools/localization-editor/index.ts --check",
    "generate:types": "ts-node tools/type-generator/index.ts"
  },
  "dependencies": {
    "pixi.js": "^8.2.0",
    "@pixi/sound": "^6.0.1",
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "framer-motion": "^11.3.19",
    "next": "^14.2.5",
    "tailwindcss": "^3.4.7",
    "better-sqlite3": "^11.1.2",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.4",
    "immer": "^10.1.1",
    "eventemitter3": "^5.0.1",
    "lz-string": "^1.5.0",
    "crypto-js": "^4.2.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/howler": "^2.2.11",
    "@types/better-sqlite3": "^7.6.11",
    "@types/js-yaml": "^4.0.9",
    "@types/crypto-js": "^4.2.2",
    "@types/semver": "^7.5.8",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.3.4",
    "vitest": "^2.0.4",
    "@vitest/ui": "^2.0.4",
    "@vitest/coverage-v8": "^2.0.4",
    "typescript": "^5.5.3",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "eslint": "^8.57.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2"
  },
  "build": {
    "appId": "com.soularchitect.vn",
    "productName": "Soul Architect",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "story/**/*",
      "config/**/*",
      "localization/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/ui/icons/app-icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/ui/icons/app-icon.icns",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/ui/icons/app-icon.png",
      "category": "Game"
    }
  }
}
